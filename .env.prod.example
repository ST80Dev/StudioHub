# Template del file .env di PRODUZIONE.
# Copialo in .env sul server e VALORIZZA ogni campo. Poi non lo tocchi piu.
# NON committare mai il .env reale (.gitignore lo esclude gia).

# ---- Django ----
# Genera un valore lungo e casuale. Suggerimento:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE-ME-genera-un-valore-lungo-casuale

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=studiohub.VOSTRO-DOMINIO.TLD
DJANGO_CSRF_TRUSTED_ORIGINS=https://studiohub.VOSTRO-DOMINIO.TLD

# ---- Database ----
POSTGRES_DB=studiohub
POSTGRES_USER=studiohub
# Genera una password forte (es. 32+ caratteri):
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE-ME-password-forte
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Time zone ----
TIME_ZONE=Europe/Rome
